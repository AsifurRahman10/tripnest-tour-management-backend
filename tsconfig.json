{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",

    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",

    "types": ["node"],
    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,

    "verbatimModuleSyntax": false
  }
}
